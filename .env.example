# ─── OpenClaw AWA Worker — Environment Configuration ─────────────────────────
#
# This file serves as a template. Copy it to .env and adjust values.
#
# ⚠ Two deployment modes:
#
#   1. Docker Compose (recommended for production-like local testing):
#        docker compose up -d
#      → GCS is reachable at http://gcs-emulator:4443 (inside the Docker network)
#      → Worker listens on http://localhost:9808 (mapped to host)
#
#   2. Standalone (direct node, not in Docker):
#      The worker runs directly on the host. Chromium + system deps needed.
#      → GCS needs a separate emulator or real GCS.
#
# For the mpx-awa CLI (run from the host):
#   AWA_WORKER_URL   defaults to http://localhost:8080 (standalone) or http://localhost:9808 (Docker)
#   GCS_EMULATOR_URL defaults to http://localhost:4443

# ─── Server ───────────────────────────────────────────
PORT=8080
NODE_ENV=development

# ─── GCS (Google Cloud Storage) ────────────────────────
# Inside Docker:  http://gcs-emulator:4443
# From host:      http://localhost:4443
GCS_ENDPOINT=http://gcs-emulator:4443
GCS_BUCKET=awa-skills-dev
GCS_PROJECT_ID=openclaw-dev
# Local filesystem fallback path (used when ScriptLoader.useLocalFallback=true)
GCS_LOCAL_PATH=/workspace/data/gcs

# ─── Isolate Sandbox ──────────────────────────────────
ISOLATE_MEMORY_LIMIT_MB=128
ISOLATE_TIMEOUT_MS=30000
ISOLATE_POOL_SIZE=20

# ─── Browser Pool ─────────────────────────────────────
BROWSER_POOL_SIZE=40
CHROME_PATH=/usr/bin/chromium
PLAYWRIGHT_HEADLESS=true

# ─── Session Manager ──────────────────────────────────
SESSION_IDLE_TIMEOUT_MS=900000
MAX_SESSIONS=40

# ─── Proxy (bypass in dev) ────────────────────────────
PROXY_MODE=none
PROXY_PROVIDER_URL=
PROXY_API_KEY=

# ─── Rate Limiting ────────────────────────────────────
RATE_LIMIT_DOMAIN=10
RATE_LIMIT_GLOBAL=500

# ─── AWA SDK CLI (mpx-awa) — used externally on the host ──
AWA_WORKER_URL=http://localhost:9808
GCS_EMULATOR_URL=http://localhost:4443

# ─── Testing ─────────────────────────────────────────
MOCK_PORT=3000
RUN_E2E=false

# ─── Logging ──────────────────────────────────────────
LOG_LEVEL=debug

# ─── Logging ──────────────────────────────────────────
LOG_LEVEL=debug
