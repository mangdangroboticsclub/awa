# MPX Gateway Configuration
# Copy this file to .env and update the values for your environment.

# Gateway URL for the MPX marketplace (default: http://localhost:8080)
MPX_GATEWAY_URL=http://x.x.x.x:8080

# Worker URL for session management (default: http://localhost:9808)
AWA_WORKER_URL=http://x.x.x.x:9808
