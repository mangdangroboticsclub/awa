{
  "name": "openclaw-awa-worker",
  "version": "1.0.0",
  "description": "OpenClaw Agentic Web Actions (AWA) Multi-Tenant Runtime Engine",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "jest tests/unit --forceExit",
    "test:integration": "jest tests/integration --forceExit",
    "test:e2e": "jest tests/e2e --forceExit",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "seed": "node scripts/seed-scripts.js",
    "benchmark": "node scripts/benchmark.js",
    "clean": "rm -rf node_modules dist"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.7.0",
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "isolated-vm": "^4.7.0",
    "playwright": "^1.40.0",
    "playwright-extra": "^4.3.0",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
